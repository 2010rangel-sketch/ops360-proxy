{
  "version": 2,
  "builds": [{ "src": "public/index.html", "use": "@vercel/static" }],
  "routes": [
    { "src": "/api/nr-export", "dest": "/api/nr-export.js" },
    {
      "src": "/api/(.*)",
      "dest": "https://ops360-proxy-production.up.railway.app/api/$1",
      "headers": { "Access-Control-Allow-Origin": "*" }
    },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
